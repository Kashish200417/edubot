<%- include('partials/header') %>

<div class="flex h-screen bg-[#FDFDFD] overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-80 border-r border-gray-100 bg-white flex flex-col flex-shrink-0 z-20 shadow-[4px_0_24px_rgba(0,0,0,0.02)] transition-all relative">
        <div class="p-6 border-b border-gray-100 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-blue-600 flex items-center justify-center text-white font-bold text-xl shadow-md">E</div>
                <div>
                    <h1 class="font-bold tracking-tight text-gray-900 leading-tight">EduBot</h1>
                    <p class="text-xs text-brand-600 font-medium bg-brand-50 px-2 py-0.5 rounded inline-block mt-0.5"><%= username %></p>
                </div>
            </div>
            
        </div>

        <div class="flex-grow overflow-y-auto p-6 space-y-8 custom-scrollbar">
            <!-- Subject Selector -->
            <div>
                <label class="block text-xs uppercase tracking-wider font-semibold text-gray-400 mb-3">Study Subject</label>
                <div class="relative">
                    <select id="subject-select" class="appearance-none w-full bg-gray-50 border border-gray-200 text-gray-700 py-3.5 px-4 pr-8 rounded-2xl leading-tight focus:outline-none focus:bg-white focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 transition-all shadow-sm font-medium cursor-pointer">
                        <option value="Computer Science">💻 Computer Science</option>
                        <option value="Mathematics">📐 Mathematics</option>
                        <option value="Biology">🧬 Biology</option>
                        <option value="History">🏛️ History</option>
                        <option value="Physics">⚛️ Physics</option>
                        <option value="Chemistry">🧪 Chemistry</option>
                        <option value="Literature">📚 Literature</option>
                    </select>
                    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-500">
                        <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                    </div>
                </div>
                <p class="text-xs text-gray-500 mt-2 ml-1">Changes the AI's expertise and context.</p>
            </div>
        </div>

        <div class="p-6 border-t border-gray-100 bg-gray-50/50">
            <a href="/logout" class="flex items-center justify-center gap-2 w-full py-3 px-4 bg-white border border-gray-200 rounded-xl text-gray-700 font-medium hover:bg-red-50 hover:text-red-600 hover:border-red-100 transition-colors shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                Log Out
            </a>
        </div>
    </aside>

    <!-- Main Chat Area -->
    <main class="flex-grow flex flex-col relative w-full bg-white bg-[url('https://grainy-gradients.vercel.app/noise.svg')] bg-blend-multiply border-l border-gray-100 shadow-[inset_4px_0_24px_rgba(0,0,0,0.01)]">
        
        <!-- Subtle subtle gradient glow in center -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-tr from-brand-50/40 to-blue-50/40 rounded-full blur-[100px] pointer-events-none"></div>

        <!-- Chat Header -->
        <header class="h-16 border-b border-gray-100 bg-white/80 backdrop-blur-md flex items-center px-8 z-10 sticky top-0 shrink-0 shadow-sm">
            <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></div>
                <h2 id="current-subject-title" class="font-semibold text-gray-800 text-lg">Computer Science</h2>
            </div>
        </header>

        <!-- Messages Container -->
        <div id="chat-container" class="flex-grow overflow-y-auto p-8 space-y-8 z-10 scroll-smooth custom-scrollbar relative">
            <!-- Loader initially hidden -->
            <div id="initial-loader" class="absolute inset-0 flex flex-col items-center justify-center bg-white/50 backdrop-blur-sm z-20">
                <div class="w-10 h-10 border-4 border-gray-200 border-t-brand-500 rounded-full animate-spin"></div>
                <p class="mt-4 text-sm font-medium text-gray-500">Loading your tutor...</p>
            </div>
            
            <div id="chat-history" class="space-y-6 max-w-4xl mx-auto pb-10">
                <!-- Messages will be injected here by app.js -->
            </div>
        </div>

        <!-- Input Area -->
        <div class="p-6 bg-white/80 backdrop-blur-xl border-t border-gray-100 z-10 shrink-0 pb-8 rounded-t-3xl shadow-[0_-4px_24px_rgba(0,0,0,0.02)]">
            <div class="max-w-4xl mx-auto relative">
                <div id="error-message" class="absolute -top-12 left-0 right-0 hidden bg-red-50 text-red-600 px-4 py-2 rounded-lg text-sm font-medium border border-red-100 shadow-sm flex items-center gap-2 transform translate-y-4 opacity-0 transition-all duration-300">
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span id="error-text">An error occurred</span>
                </div>

                <form id="chat-form" class="relative flex items-end gap-3 p-1 rounded-3xl bg-gray-50 border border-gray-200 focus-within:border-brand-500 focus-within:ring-4 focus-within:ring-brand-500/10 transition-all shadow-sm hover:shadow-md">
                    <textarea id="message-input" rows="1" class="flex-grow bg-transparent border-none focus:ring-0 resize-none py-4 px-5 text-gray-700 placeholder-gray-400 max-h-32 min-h-[56px] custom-scrollbar" placeholder="Ask your tutor anything..."></textarea>
                    
                    <button type="submit" id="send-btn" class="mb-1 p-3.5 bg-brand-600 hover:bg-brand-500 text-white rounded-2xl shadow-md transition-all flexitems-center justify-center group disabled:opacity-50 disabled:cursor-not-allowed transform hover:-translate-y-0.5 disabled:hover:translate-y-0 mr-1">
                        <svg class="w-5 h-5 transform rotate-90 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19V6m0 0l-8 8m8-8l8 8"></path></svg>
                    </button>
                </form>
                <div class="text-center mt-3 text-[11px] text-gray-400 font-medium tracking-wide">
                    EduBot uses Gemini. Responses may contain inaccuracies.
                </div>
            </div>
        </div>
    </main>
</div>

<script src="/js/app.js"></script>

<%- include('partials/footer') %>
