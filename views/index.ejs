<%- include('partials/header') %>

<div class="relative min-h-screen flex flex-col overflow-hidden bg-white">
    <!-- Decorative background elements -->
    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 pointer-events-none"></div>
    <div class="absolute top-0 right-0 -mr-[10%] -mt-[10%] w-[50%] h-[50%] rounded-full bg-gradient-to-br from-brand-100 to-brand-500 opacity-20 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 -ml-[10%] -mb-[10%] w-[50%] h-[50%] rounded-full bg-gradient-to-tr from-blue-100 to-purple-300 opacity-20 blur-3xl pointer-events-none"></div>

    <nav class="relative z-10 w-full max-w-7xl mx-auto px-6 py-6 flex justify-between items-center">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-blue-600 flex items-center justify-center text-white font-bold text-xl shadow-lg">E</div>
            <span class="text-xl font-bold tracking-tight text-gray-900">EduBot</span>
        </div>
        <div class="flex items-center gap-4">
            <a href="/login" class="text-gray-600 hover:text-gray-900 font-medium transition-colors">Log In</a>
            <a href="/register" class="bg-gray-900 hover:bg-gray-800 text-white px-5 py-2.5 rounded-full font-medium transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">Sign Up</a>
        </div>
    </nav>

    <main class="relative z-10 flex-grow flex items-center justify-center px-6">
        <div class="max-w-4xl mx-auto text-center space-y-8">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-50 text-brand-600 font-medium text-sm border border-brand-100 shadow-sm animate-fade-in-up">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-500"></span>
                </span>
                Powered by Gemini 2.5 Flash
            </div>
            
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-gray-900 leading-tight">
                Your Personal <br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-500 to-blue-600">AI Academic Tutor</span>
            </h1>
            
            <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
                Master any subject with a highly intelligent, context-aware chatbot. From Quantum Physics to World History, EduBot adapts to your learning needs.
            </p>
            
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
                <a href="/register" class="w-full sm:w-auto px-8 py-4 bg-gray-900 hover:bg-gray-800 text-white rounded-full font-semibold text-lg transition-all shadow-xl hover:shadow-2xl transform hover:-translate-y-1">
                    Start Learning Free
                </a>
                <a href="/login" class="w-full sm:w-auto px-8 py-4 bg-white text-gray-900 border border-gray-200 hover:border-gray-300 rounded-full font-semibold text-lg transition-all shadow-sm hover:shadow-md">
                    Welcome Back
                </a>
            </div>
        </div>
    </main>
</div>

<%- include('partials/footer') %>
